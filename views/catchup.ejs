<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="utf-8" />
  <title>Catch Up – Study Team</title>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.1/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/css/master.css">
</head>
<body>
  <div class="container viewpage" style="max-width: 100%; width: 100%;">
    <div class="row align-items-start" style="min-height: 100vh;">

        <!-- Profile / Sidebar -->
        <div class="col-2">
          <a class="btn btn-white" href="/study" role="button"><img src="/images/rerite.png" id="logoinpage" style="margin: 5%;" alt=""></a>
        <br><br>
        <div class="container-fluid">
        <p class="text-center text-muted profile-enrollment"><%= userEnrollment %></p>
      </div>
        </nav>
        <div class="accordion accordion-flush" id="accordionFlushExample">
          <div class="accordion-item">
          </div>
        </div>
        <p></p>
        <p></p>
        <p></p>
        <p></p>
        <p></p>
        </div>

<div class="col-8 pt-3 main-content">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary">Catch Up with Study Team</h2>
    <a class="btn btn-secondary" href="/study">Back to Study</a>
  </div>

    <% if (!comments || comments.length === 0) { %>
      <div class="empty-accordion-placeholder">
        <div class="alert alert-info">No comments or queries from study team members yet.</div>
      </div>
    <% } else { %>

      <div id="listAccordion" class="accordion">
        <% comments.forEach(function(comment, idx) { 
            const collapseId = `collapse-${comment._id || idx}`;
            const headingId = `heading-${comment._id || idx}`;
        %>

          <div class="accordion-item mb-3">
            <h2 class="accordion-header" id="<%= headingId %>">
              <button class="accordion-button <%= idx === 0 ? '' : 'collapsed' %>" type="button" data-bs-toggle="collapse" data-bs-target="#<%= collapseId %>" aria-expanded="<%= idx === 0 ? 'true' : 'false' %>" aria-controls="<%= collapseId %>">
                <div class="w-100">
                  <div class="d-flex justify-content-between align-items-start">
                    <div>
                      <% if (comment.myagreecomment) { %>
                        <h5 class="mb-1"><span class="badge bg-success">Agree</span> <%= comment.arg.ida || 'Unknown' %></h5>
                      <% } else if (comment.myquerycomment) { %>
                        <h5 class="mb-1"><span class="badge bg-warning">Query</span> <%= comment.arg.ida || 'Unknown' %></h5>
                      <% } %>
                      <h6 class="mb-0"><%= comment.arg.marg || 'N/A' %></h6>
                    </div>
                    <div class="text-end">
                      <small class="text-muted"><%= comment.arg.id3 || '' %></small><br/>
                    </div>
                  </div>
                </div>
              </button>
            </h2>

            <div id="<%= collapseId %>" class="accordion-collapse collapse <%= idx === 0 ? 'show' : '' %>" aria-labelledby="<%= headingId %>" data-bs-parent="#listAccordion">
              <div class="accordion-body">

                <!-- Comment Section -->
                <div class="alert <%= comment.myagreecomment ? 'alert-success' : 'alert-warning' %>">
                  <strong><%= comment.myagreecomment ? 'Agree' : 'Query' %> by <%= comment.myenrollmentnumber %></strong>
                  <p class="mb-0 mt-2"><%= comment.myagreecomment || comment.myquerycomment %></p>
                </div>

                <!-- Argument Content -->
                <% if (comment.arg.marg) { %>
                  <p class="mb-1"><strong>Main Argument:</strong></p>
                  <p class="mb-3"><%= comment.arg.marg %></p>
                <% } %>

                <% if (comment.arg.sarg1 || comment.arg.sarg2 || comment.arg.sarg3) { %>
                  <p class="mb-1"><strong>Supporting Arguments:</strong></p>
                  <ul>
                    <% if (comment.arg.sarg1) { %><li><%= comment.arg.sarg1 %></li><% } %>
                    <% if (comment.arg.sarg2) { %><li><%= comment.arg.sarg2 %></li><% } %>
                    <% if (comment.arg.sarg3) { %><li><%= comment.arg.sarg3 %></li><% } %>
                  </ul>
                <% } %>

                <% if (comment.arg.trm || comment.arg.texp) { %>
                  <p class="mb-1"><strong><%= comment.arg.trm || '' %></strong></p>
                  <p class="mb-2"><%= comment.arg.texp || '' %></p>
                <% } %>

                <% if (comment.arg.pnt1 || comment.arg.pnt2 || comment.arg.pnt3 || comment.arg.pnt4 || comment.arg.pnt5) { %>
                  <p class="mb-1"><strong>Key Points:</strong></p>
                  <ul>
                    <% if (comment.arg.pnt1) { %><li><%= comment.arg.pnt1 %></li><% } %>
                    <% if (comment.arg.pnt2) { %><li><%= comment.arg.pnt2 %></li><% } %>
                    <% if (comment.arg.pnt3) { %><li><%= comment.arg.pnt3 %></li><% } %>
                    <% if (comment.arg.pnt4) { %><li><%= comment.arg.pnt4 %></li><% } %>
                    <% if (comment.arg.pnt5) { %><li><%= comment.arg.pnt5 %></li><% } %>
                  </ul>
                <% } %>

                <% if (comment.arg.njs || comment.arg.opd) { %>
                  <p class="text-muted mt-3">
                    <strong><%= comment.arg.njs || '' %></strong>
                    <% if (comment.arg.opd) { %> — <%= new Date(comment.arg.opd).toLocaleDateString("en-IN", { year:"numeric", month:"long", day:"numeric" }) %><% } %>
                  </p>
                <% } %>

              </div>
            </div>
          </div>

        <% }) %>
      </div>

    <% } %>
  </div>

  <!-- Right Sidebar Placeholder -->
  <div class="col-2"></div>
  </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.1/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
