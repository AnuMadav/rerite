<script>
document.addEventListener('DOMContentLoaded', function () {
  // Close other accordions when one opens
  document.addEventListener('show.bs.collapse', function (e) {
    const accordion = document.getElementById('accordionFlushExample');
    if (!accordion) return;

    const collapses = accordion.querySelectorAll('.accordion-collapse');
    collapses.forEach(collapse => {
      if (collapse !== e.target) {
        const bsCollapse = bootstrap.Collapse.getInstance(collapse);
        if (bsCollapse) {
          bsCollapse.hide();
        } else {
          new bootstrap.Collapse(collapse, { toggle: false }).hide();
        }
      }
    });
  });
  // Referred button redirect
  const btnRef = document.getElementById('btnReferred');
  if (btnRef) {
    btnRef.addEventListener('click', function () {
      let ern = '';
      const ernInput = document.getElementById('ERN1');
      if (ernInput && ernInput.value) ern = ernInput.value.trim();
      if (!ern) {
        const prof = document.querySelector('.profile-enrollment');
        if (prof) ern = prof.textContent.trim();
      }
      if (!ern) ern = 'ERN000012025';
      window.location.href = '/referred/' + encodeURIComponent(ern);
    });
  }
});
</script>

