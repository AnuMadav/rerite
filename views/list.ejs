<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="utf-8" />
  <title>List – <%= listname %></title>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.1/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/css/master.css">
</head>
<body>
  <div class="container viewpage">
    <div class="row align-items-start">

        <!-- Profile Pic -->
        <div class="col-2">
          <a class="btn btn-white" href="/study" role="button"><img src="/images/rerite.png" id="logoinpage" style="margin: 5%;" alt=""></a>
        <br><br>
        <div class="container">
        <p class="text-center text-muted profile-enrollment"><%= userEnrollment %></p>
      </div>
        <div class="accordion accordion-flush" id="accordionFlushExample">
          <div class="accordion-item">
            <h2 class="accordion-header" id="flush-headingOne">
              <button class="accordion-button collapsed text-center" type="button" data-bs-toggle="collapse" data-bs-target="#flush-collapseOne" aria-expanded="false" aria-controls="flush-collapseOne">
                Search by topics
              </button>
            </h2>
            <div id="flush-collapseOne" class="accordion-collapse collapse collapsebckgrd" aria-labelledby="flush-headingOne" data-bs-parent="#accordionFlushExample">
              <nav class="navbar navbar-light justify-content-center">
                <a class="btn btn-white" href="/basicsearch" role="button">Search by topics</a>
                <a class="btn btn-white" href="/advancedsearch" role="button">Search by text</a>
              </nav>
            </div>          
          </div>
          <div class="accordion-item" id="savedlistaccordion">
            <h2 class="accordion-header" id="flush-headingTwo">
              <button class="accordion-button collapsed text-center" type="button" data-bs-toggle="collapse" data-bs-target="#flush-collapseTwo" aria-expanded="false" aria-controls="flush-collapseTwo">
                Saved Lists
              </button>
            </h2>
            <div id="flush-collapseTwo" class="accordion-collapse collapse collapsebckgrd" aria-labelledby="flush-headingTwo" data-bs-parent="#accordionFlushExample">
              <nav class="navbar navbar-light">
                <ul>
                  <% for (var j = Math.max(0, mylistnames.length - 3); j < mylistnames.length; j++) { %>
                    <a href="/list/<%= mylistnames[j] %>" 
                      class="btn btn-white justify-content-center" 
                      style="margin-left:-20%;">
                      <%= mylistnames[j] %>
                    </a>
                    <br>
                  <% } %>
                </ul>               
                <button class="btn btn-primary justify-content-between" style="margin-left:20%;" data-bs-toggle="modal" data-bs-target="#modalList">Add New List</button>
                

             <!-- Modal -->
             <div class="modal fade" id="modalList" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
              <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                  <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLongTitle">New List</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                  </div>
                  <div class="modal-body">
                    <form action="/study" method="post">
                      <div class="form-group">
                        <label for="main-group" class="col-form-label">Enrollment Number</label>
                        <input autocomplete='off' class='form-control' type="text" name="myenrollmentnumber" id="ERN1" value="<%= userEnrollment %>">
                        <label for="main-group" class="col-form-label">List Name</label>
                        <input type="text" class="form-control" name="listname">
                      </div>     
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" name="submit" class="btn btn-primary">Save changes</button>
                  </form>
                  </div>
                </div>
              </div>
            </div> 
              </nav>
            </div>          
          </div>
          <p></p>
          <p></p>
          <p></p>
          <p></p>
          <p></p>
          
          
          </div>

        </div>


<div class="col-8 pt-3 main-content">
  <h2 class="text-center"> <%= listname %></h2>
  <small class="text-muted"><%= userEnrollment %></small>
<br>
<div id= "overflow">
<ul>
  <% if (!args || args.length === 0) { %>
      <div class="empty-accordion-placeholder">
        <div class="alert alert-info mt-3">No arguments saved in this list yet.</div>
      </div>
  <% } else { %>

      <div class="accordion" id="listAccordion">
        <% args.forEach(function(arg, idx) { 
            // safe fallbacks
            const collapseId = `collapse-${arg.ida || 'x'}-${idx}`;
            const headingId = `heading-${arg.ida || 'x'}-${idx}`;
            const modalSaveId = `modalSave-${arg.ida || 'x'}-${idx}`;
            const modalAgreeId = `modalAgree-${arg.ida || 'x'}-${idx}`;
            const modalQueryId = `modalQuery-${arg.ida || 'x'}-${idx}`;
            const modalReferId = `modalRefer-${arg.ida || 'x'}-${idx}`;
        %>

          <div class="accordion-item mb-3">
            <h2 class="accordion-header" id="<%= headingId %>">
              <button class="accordion-button <%= idx === 0 ? '' : 'collapsed' %>" type="button" data-bs-toggle="collapse" data-bs-target="#<%= collapseId %>" aria-expanded="<%= idx === 0 ? 'true' : 'false' %>" aria-controls="<%= collapseId %>">
                <div class="w-100">
                  <div class="d-flex justify-content-between align-items-start">
                    <div>
                      <h5 class="mb-1"><%= arg.ida %></h5>
                      <h6 class="mb-0"><%= arg.marg %></h6>
                    </div>
                    <div class="text-end">
                      <small class="text-muted"><%= arg.id3 || '' %></small><br/>
                      <% if (arg.nws) { %><small><%= arg.nws %></small><br/><% } %>
                    </div>
                  </div>
                </div>
              </button>
            </h2>

            <div id="<%= collapseId %>" class="accordion-collapse collapse <%= idx === 0 ? 'show' : '' %>" aria-labelledby="<%= headingId %>" data-bs-parent="#listAccordion">
              <div class="accordion-body">

                <!-- content (no supporting labels, just content) -->
                <% if (arg.trm || arg.texp) { %>
                  <p class="mb-1"><strong><%= arg.trm || '' %></strong></p>
                  <p class="mb-2"><%= arg.texp || '' %></p>
                <% } %>

                <% if (arg.pnt1 || arg.pnt2 || arg.pnt3 || arg.pnt4 || arg.pnt5) { %>
                  <ul>
                    <% if (arg.pnt1) { %><li><%= arg.pnt1 %></li><% } %>
                    <% if (arg.pnt2) { %><li><%= arg.pnt2 %></li><% } %>
                    <% if (arg.pnt3) { %><li><%= arg.pnt3 %></li><% } %>
                    <% if (arg.pnt4) { %><li><%= arg.pnt4 %></li><% } %>
                    <% if (arg.pnt5) { %><li><%= arg.pnt5 %></li><% } %>
                  </ul>
                <% } %>

                <% if (arg.btle) { %>
                  <p class="mb-1"><strong>Book:</strong> <%= arg.btle %> — <%= arg.btar || '' %> (<%= arg.bpne || '' %>)</p>
                <% } %>

                <% if (arg.opnn || arg.opn1 || arg.opnb) { %>
                  <p class="mb-1"><strong>Opinion:</strong> <%= arg.opnn || '' %></p>
                  <% if (arg.opn1 || arg.opnb) { %>
                    <p class="mb-1"><%= arg.opn1 || '' %> — <%= arg.opnb || '' %></p>
                  <% } %>
                <% } %>

                <% if (arg.njs || arg.opd) { %>
                  <p class="text-muted mt-3">
                    <strong><%= arg.njs || '' %></strong>
                    <% if (arg.opd) { %> — <%= new Date(arg.opd).toLocaleDateString("en-IN", { year:"numeric", month:"long", day:"numeric" }) %><% } %>
                  </p>
                <% } %>

                <!-- action buttons & modals (one set inside each arg) -->
                <div class="mt-3">
                  <div class="btn-group" role="group">
                    <!-- Save modal trigger -->
                    <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#<%= modalSaveId %>">Save to</button>

                    <!-- Agree modal trigger -->
                    <button type="button" class="btn btn-sm btn-outline-success" data-bs-toggle="modal" data-bs-target="#<%= modalAgreeId %>">Agree</button>

                    <!-- Query modal trigger -->
                    <button type="button" class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#<%= modalQueryId %>">Post a Query</button>

                    <!-- Refer modal trigger -->
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#<%= modalReferId %>">Refer to</button>
                  </div>
                </div>

                <!-- Save Modal -->
                <div class="modal fade" id="<%= modalSaveId %>" tabindex="-1" aria-hidden="true">
                  <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                      <form action="/study" method="post">
                        <div class="modal-header">
                          <h5 class="modal-title">Save "<%= arg.ida %>" to list</h5>
                          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                          <input type="hidden" name="myuida" value="<%= arg.ida %>">
                          <div class="mb-2">
                            <label class="form-label">Your enrollment number</label>
                            <input class="form-control" name="myenrollmentnumber" value="<%= userEnrollment %>" placeholder="ERN..." />
                          </div>

                          <div class="mb-2">
                            <label class="form-label">Choose list(s)</label>
                            <% if (mylistnames && mylistnames.length) { %>
                              <% mylistnames.forEach(function(ln, li){ %>
                                <div class="form-check">
                                  <input class="form-check-input" type="checkbox" name="listargname" id="list-<%= li %>-<%= idx %>" value="<%= ln %>">
                                  <label class="form-check-label" for="list-<%= li %>-<%= idx %>"><%= ln %></label>
                                </div>
                              <% }) %>
                            <% } else { %>
                              <p class="text-muted">No lists found. Create a list first from Study page.</p>
                            <% } %>
                          </div>

                          <div class="mb-2">
                            <label class="form-label">Or create new list</label>
                            <input class="form-control" name="listname" placeholder="New list name (optional)"/>
                          </div>
                        </div>
                        <div class="modal-footer">
                          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                          <button type="submit" class="btn btn-primary">Save</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>

                <!-- Agree Modal -->
                <div class="modal fade" id="<%= modalAgreeId %>" tabindex="-1" aria-hidden="true">
                  <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                      <form action="/study" method="post">
                        <div class="modal-header">
                          <h5 class="modal-title">Agree with "<%= arg.ida %>"</h5>
                          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                          <input type="hidden" name="anuida" value="<%= arg.ida %>">
                          <div class="mb-2">
                            <label class="form-label">Your enrollment number</label>
                            <input class="form-control" name="myenrollmentnumber" value="<%= userEnrollment %>" placeholder="ERN..." />
                          </div>
                          <div class="mb-2">
                            <label class="form-label">Comment</label>
                            <textarea class="form-control" name="agreecomment" rows="3"></textarea>
                          </div>
                        </div>
                        <div class="modal-footer">
                          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                          <button type="submit" class="btn btn-success">Post Agree</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>

                <!-- Query Modal -->
                <div class="modal fade" id="<%= modalQueryId %>" tabindex="-1" aria-hidden="true">
                  <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                      <form action="/study" method="post">
                        <div class="modal-header">
                          <h5 class="modal-title">Query about "<%= arg.ida %>"</h5>
                          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                          <input type="hidden" name="anuida" value="<%= arg.ida %>">
                          <div class="mb-2">
                            <label class="form-label">Your enrollment number</label>
                            <input class="form-control" name="myenrollmentnumber" value="<%= userEnrollment %>" placeholder="ERN..." />
                          </div>
                          <div class="mb-2">
                            <label class="form-label">Query</label>
                            <textarea class="form-control" name="querycomment" rows="3"></textarea>
                          </div>
                        </div>
                        <div class="modal-footer">
                          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                          <button type="submit" class="btn btn-warning">Post Query</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>

                <!-- Refer Modal -->
                <div class="modal fade" id="<%= modalReferId %>" tabindex="-1" aria-hidden="true">
                  <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                      <form action="/study" method="post">
                        <div class="modal-header">
                          <h5 class="modal-title">Refer "<%= arg.ida %>" to members</h5>
                          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                          <input type="hidden" name="uruida" value="<%= arg.ida %>">
                          <div class="mb-2">
                            <label class="form-label">Your enrollment number</label>
                            <input class="form-control" name="myenrollmentnumber" value="<%= userEnrollment %>" placeholder="ERN..." />
                          </div>
                          <div class="mb-2">
                            <label class="form-label">Choose members</label>
                            <% if (urusernames && urusernames.length) { %>
                              <% urusernames.forEach(function(u, ui) { %>
                                <div class="form-check">
                                  <input class="form-check-input" type="checkbox" name="urenrollrefname" id="user-<%= ui %>-<%= idx %>" value="<%= u %>">
                                  <label class="form-check-label" for="user-<%= ui %>-<%= idx %>"><%= u %></label>
                                </div>
                              <% }) %>
                            <% } else { %>
                              <p class="text-muted">No study-team members found.</p>
                            <% } %>
                          </div>
                        </div>
                        <div class="modal-footer">
                          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                          <button type="submit" class="btn btn-primary">Refer</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>

              </div> <!-- accordion-body -->
            </div> <!-- collapse -->
          </div> <!-- accordion-item -->

        <% }) %>
      </div> <!-- accordion -->
  <% } %>
</ul>
</div>

  </div> <!-- col-8 -->
          
  <div class="col-2">
  </div>
  </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.1/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
